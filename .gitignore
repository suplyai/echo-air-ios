# macOS
.DS_Store

# Xcode build / user state
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Generated by xcodegen — project.yml is the source of truth.
EchoAir.xcodeproj/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# CocoaPods (added in phase 2; pods themselves are not vendored)
Pods/
Podfile.lock

# Generated by `pod install`.
EchoAir.xcworkspace/

# Local-only build settings (DEVELOPMENT_TEAM etc.). Use the .template file
# in version control; the real Local.xcconfig stays out of public history.
Config/Local.xcconfig

# Fastlane (if/when added)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Editor cruft
*.swp
*.swo
*~
.idea/
.vscode/
