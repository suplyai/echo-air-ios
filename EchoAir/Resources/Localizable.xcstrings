      }
    },
    "failure_device_not_assigned_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This device is registered but isn't currently assigned to an active shipment. Contact your shipper." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Este dispositivo está registrado pero no está asignado a un envío activo. Contacta a tu embarcador." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "此设备已注册,但当前未绑定到进行中的货运。请联系发货人。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "このデバイスは登録済みですが、現在進行中の貨物に紐づいていません。荷送人にご連絡ください。" } }
      }
    },
