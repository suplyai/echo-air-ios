        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure you're scanning the QR label printed on an Echo Air device." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Asegúrate de estar escaneando la etiqueta QR impresa en un dispositivo Echo Air." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "请确认您正在扫描 Echo Air 设备上印刷的二维码。" } },
