    "location_rationale_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Attach location to each scan?" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Adjuntar ubicación a cada escaneo?" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "是否为每次扫描附加位置?" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "各スキャンに位置情報を付与しますか?" } }
      }
    },
    "location_rationale_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air attaches the scan location to the shipment's audit trail, so the timeline shows where each device was scanned. Your location is only captured when you scan a device." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air adjunta la ubicación del escaneo al registro del envío, para que la línea de tiempo muestre dónde se escaneó cada dispositivo. Tu ubicación solo se captura cuando escaneas un dispositivo." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air 会将扫描位置附加到货运的审计记录，以便时间线显示每台设备的扫描地点。仅在您扫描设备时捕获位置。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air はスキャン位置を貨物の監査記録に付与し、各デバイスがどこでスキャンされたかをタイムラインに表示します。位置情報はデバイスをスキャンした瞬間のみ取得されます。" } }
      }
    },
    "location_rationale_accept" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Allow" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Permitir" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "允许" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "許可" } }
      }
    },
    "location_rationale_decline" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Not now" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ahora no" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "暂不" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "後で" } }
      }
    },

