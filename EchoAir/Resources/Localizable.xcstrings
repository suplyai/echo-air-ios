    "app_name" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air" } }
      }
    },

    "home_intro_primary" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter an air waybill or container number, or scan any device QR code — we'll automatically identify and connect all devices in the shipment." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Introduce un número de guía aérea o de contenedor, o escanea el código QR de cualquier dispositivo — identificaremos y conectaremos automáticamente todos los dispositivos del envío." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "输入空运提单号或集装箱号，或扫描任意设备二维码 — 我们将自动识别并连接货运中的所有设备。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "航空運送状番号またはコンテナ番号を入力するか、デバイスのQRコードをスキャンしてください — 出荷内のすべてのデバイスを自動的に識別して接続します。" } }
      }
    },
    "home_intro_positioning" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stand close to the cargo where the device is attached, at the container door, or beside the ULD or pallets." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Mantente cerca de la carga donde está colocado el dispositivo, en la puerta del contenedor, o junto al ULD o los palés." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "请靠近设备所在的货物、集装箱门口，或ULD或托盘旁边。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "デバイスが取り付けられている貨物、コンテナのドア、またはULDやパレットの近くに立ってください。" } }
      }
    },
    "home_action_awb_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter your air waybill number" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ingrese el número de su guía aérea" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "输入航空运单号" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "航空運送状番号を入力" } }
