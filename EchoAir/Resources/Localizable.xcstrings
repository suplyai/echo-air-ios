    "failure_timeout_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suply servers aren't responding" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Los servidores de Suply no responden" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Suply 服务器未响应" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Suply サーバーが応答しません" } }
      }
    },
    "failure_timeout_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This usually clears up after a few seconds. Try again." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Esto suele resolverse en pocos segundos. Intenta nuevamente." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "通常几秒钟后即可恢复。请重试。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "通常は数秒で解消します。再試行してください。" } }
      }
    },
    "failure_server_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Something went wrong" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Algo salió mal" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "出错了" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "エラーが発生しました" } }
      }
    },
    "failure_server_body_with_code" : {
      "comment" : "%1$lld = HTTP status code (e.g. 500, 503)",
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suply returned an error (HTTP %1$lld). Try again in a moment, or contact your shipper if it keeps happening." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Suply devolvió un error (HTTP %1$lld). Intenta nuevamente en un momento o contacta a tu embarcador si persiste." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Suply 返回了错误 (HTTP %1$lld)。请稍后重试;如问题持续,请联系发货人。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Suply がエラーを返しました (HTTP %1$lld)。しばらく経ってから再試行するか、解消しない場合は荷送人にご連絡ください。" } }
      }
    },
    "failure_server_body_unknown" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unexpected error. Try again in a moment." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Error inesperado. Intenta nuevamente en un momento." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "发生未知错误。请稍后重试。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "予期しないエラーが発生しました。しばらく経ってから再試行してください。" } }
      }
    },
    "failure_malformed_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unexpected response from Suply" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Respuesta inesperada de Suply" } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Suply 返回了意外的响应" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Suply から想定外のレスポンス" } }
      }
    },
    "failure_malformed_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The server responded in a shape the app didn't recognise — usually means the backend was updated without the app catching up. Ask your shipper to check the deployment." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El servidor respondió con un formato que la app no reconoce — normalmente significa que el backend se actualizó sin que la app se actualizara también. Pide a tu embarcador que revise el despliegue." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "服务器返回的数据格式应用无法识别 — 通常意味着后端已更新但应用尚未同步。请联系发货人检查部署。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "サーバーの応答形式をアプリが認識できません — 通常はバックエンドが更新されたがアプリが追従していないことを意味します。荷送人にデプロイの確認を依頼してください。" } }
      }
    },
