    "permission_camera_rationale" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air needs camera access to identify shipments from their documents." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air necesita acceso a la cámara para identificar envíos desde sus documentos." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air 需要相机权限以通过单据识别货运。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air は書類から貨物を識別するためにカメラへのアクセスを必要とします。" } }
      }
    },
    "permission_ble_rationale" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air needs Bluetooth permission to collect data from shipment loggers." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air necesita permiso de Bluetooth para recolectar datos de los registradores del envío." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air 需要蓝牙权限以从货运记录器中收集数据。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Echo Air は貨物ロガーからデータを収集するために Bluetooth 権限を必要とします。" } }
      }
    },
    "permission_location_rationale" : {
      "comment" : "Android-specific copy — references Android by name. iOS will introduce a parallel iOS-appropriate key in Phase 5 if needed; this stays unused on iOS.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Android requires location permission before it will scan for Bluetooth devices. Some phone manufacturers (Honor, Huawei, Xiaomi) require this even on newer Android versions. Echo Air does not read or use your location itself." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Android requiere permiso de ubicación antes de escanear dispositivos Bluetooth. Algunos fabricantes (Honor, Huawei, Xiaomi) lo exigen incluso en versiones recientes de Android. Echo Air no lee ni utiliza tu ubicación." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "Android 在扫描蓝牙设备前需要位置权限。部分厂商 (荣耀、华为、小米) 即使在较新版本上也强制要求此权限。Echo Air 不会读取或使用您的位置。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Android は Bluetooth デバイスをスキャンする前に位置情報の許可を要求します。一部メーカー (Honor、Huawei、Xiaomi) では新しい Android バージョンでもこれを要求します。Echo Air は位置情報自体を読み取ったり使用したりすることはありません。" } }
      }
    },

